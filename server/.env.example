NODE_ENV=development
PORT=4000
APP_NAME=Mini Facebook API
APP_URL=http://localhost:4000
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mini_facebook?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
CLOUDINARY_FOLDER=mini-facebook

MAX_IMAGE_SIZE_BYTES=5242880
